{
  "name": "amicale-pompiers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"process.chdir(process.env.INIT_CWD||process.cwd());require('child_process').execSync('npx next build --webpack',{stdio:'inherit'})\"",
    "start": "next start",
    "start:prod": "node server.js",
    "lint": "eslint",
    "postinstall": "node -e \"process.chdir(process.env.INIT_CWD||process.cwd());require('child_process').execSync('npx prisma generate --schema=./prisma/schema.prisma',{stdio:'inherit'})\"",
    "db:seed": "node -e \"process.chdir(process.env.INIT_CWD||process.cwd());require('child_process').execSync('npx tsx prisma/seed.ts',{stdio:'inherit'})\"",
    "db:studio": "node -e \"process.chdir(process.env.INIT_CWD||process.cwd());require('child_process').execSync('npx prisma studio',{stdio:'inherit'})\"",
    "db:deploy": "node -e \"process.chdir(process.env.INIT_CWD||process.cwd());require('child_process').execSync('npx prisma migrate deploy --schema=./prisma/schema.prisma',{stdio:'inherit'})\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-slot": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
